{
  "language": "japanese",
  "permissions": {
    "defaultMode": "auto"
  },
  "model": "opus",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/session-start-superpowers.sh\"",
            "async": false
          }
        ]
      }
    ]
  }
}
